{
    // Deve coincidir com liveServer.settings em .vscode/settings.json (host + port).
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Chrome — Live Server (127.0.0.1:5500)",
            "url": "http://127.0.0.1:5500",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "chrome",
            "request": "attach",
            "name": "Chrome — anexar (depuração remota na 9222)",
            "port": 9222,
            "webRoot": "${workspaceFolder}"
        }
    ]
}
